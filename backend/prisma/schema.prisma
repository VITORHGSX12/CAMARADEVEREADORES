datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model TableVereador {
  id             String   @id @default(uuid())
  cargo          String   
  nomeCompleto   String
  nomeEleitoral  String
  dataNascimento String
  cpf            String   @unique
  nomeMae        String
  partido        String?
  sigla          String?
  foto           String?  @db.Text
  username       String   @unique
  senha          String
  status         String   @default("Ausente")
  voto           String   @default("Aguardando")
  pedidoFala     Boolean  @default(false)
  votos          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("vereadores")
}