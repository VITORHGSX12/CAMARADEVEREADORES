datasource db {
  provider = "postgresql" // ou "sqlite", dependendo do banco que for usar no seu .env
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// DEFINIÇÃO DA TABELA DE VEREADORES
model TableVereador {
  id        String   @id @default(uuid())
  nome      String
  partido   String
  votos     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vereadores")
}